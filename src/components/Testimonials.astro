---
import { testimonials, reviewPlatforms } from "../data/site";
import Icon from "./Icon.astro";
---
<section style="background:#f4eee1">
  <div class="wrap" style="padding-top:74px;padding-bottom:74px">
    <div style="text-align:center;max-width:640px;margin:0 auto 40px">
      <div style="font:600 12.5px/1 var(--font-body);letter-spacing:.14em;text-transform:uppercase;color:#b3303a;margin-bottom:12px">Reviews</div>
      <h2 style="font:700 40px/1.05 var(--font-display);letter-spacing:.01em;color:#16243d;margin-bottom:18px;text-wrap:balance">What Our Neighbors Say</h2>
      <div style="display:flex;align-items:center;justify-content:center;gap:18px;flex-wrap:wrap;color:#5b6675;font:600 13px/1 var(--font-body)">
        {reviewPlatforms.map((p) => (
          <span style="display:flex;align-items:center;gap:7px">
            {p === "Google" && <span style="color:#4285F4;display:flex"><Icon name="google" size={18} /></span>}
            {p === "Facebook" && <span style="color:#1877F2;display:flex"><Icon name="facebook" size={18} /></span>}
            {p !== "Google" && p !== "Facebook" && <span style="color:#b3303a;display:flex"><Icon name="star" size={16} /></span>}
            {p}
          </span>
        ))}
      </div>
    </div>

    <div class="grid-3" style="display:grid;grid-template-columns:repeat(3,1fr);gap:22px">
      {testimonials.map((t) => (
        <div class="card" style="padding:28px;display:flex;flex-direction:column;gap:14px">
          <span style="display:flex;gap:2px;color:#f0b429">
            <Icon name="star" size={17} /><Icon name="star" size={17} /><Icon name="star" size={17} /><Icon name="star" size={17} /><Icon name="star" size={17} />
          </span>
          <p style="font:400 15.5px/1.7 var(--font-body);color:#42505f;flex:1">{t.quote}</p>
          <div style="font:700 14.5px/1.3 var(--font-body);color:#16243d">{t.name} <span style="font-weight:500;color:#5b6675">&middot; {t.town}</span></div>
        </div>
      ))}
    </div>
    <p style="text-align:center;font:400 13px/1.5 var(--font-body);color:#8a92a0;margin-top:24px">Real reviews coming soon — we're building our reputation one meticulous job at a time.</p>
  </div>
</section>
