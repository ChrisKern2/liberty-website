---
import { business, services, towns } from "../data/site";
import Icon from "./Icon.astro";
import Logo from "./Logo.astro";
const year = 2026;
const social = [
  { name: "facebook", url: business.social.facebook },
  { name: "instagram", url: business.social.instagram },
  { name: "google", url: business.social.google },
];
---
<footer style="background:#0f1a30">
  <div class="wrap" style="padding-top:56px;padding-bottom:40px;display:flex;flex-direction:column;gap:40px">
    <div style="display:grid;grid-template-columns:1.4fr 1fr 1fr 1.2fr;gap:36px">
      <!-- Brand -->
      <div style="display:flex;flex-direction:column;gap:16px;align-items:flex-start">
        <Logo variant="light" size={30} />
        <p style="font:400 14px/1.6 var(--font-body);color:#9aa6b5;max-width:280px">Professional window cleaning, pressure washing, and gutter care for Montgomery &amp; Chester County. Locally owned, licensed, and fully insured.</p>
        <p style="font:600 12.5px/1.5 var(--font-body);color:#7d899a">Licensed &amp; Insured &middot; PA HIC #{`{{HIC_NUMBER}}`}</p>
        <div style="display:flex;gap:10px">
          {social.map((s) => (
            <a href={s.url.startsWith("{{") ? "#" : s.url} aria-label={s.name} class="foot-link" style="width:36px;height:36px;border-radius:9px;background:rgba(255,255,255,.06);display:flex;align-items:center;justify-content:center;color:#c9d0db">
              <Icon name={s.name} size={18} />
            </a>
          ))}
        </div>
      </div>

      <!-- Services -->
      <div style="display:flex;flex-direction:column;gap:12px">
        <div style="font:600 11px/1 var(--font-body);letter-spacing:.16em;text-transform:uppercase;color:#cf6a6f">Services</div>
        {services.map((s) => (
          <a class="foot-link" href={`/services/${s.slug}`} style="font:400 14.5px/1.3 var(--font-body)">{s.name}</a>
        ))}
        <a class="foot-link" href="/about" style="font:400 14.5px/1.3 var(--font-body)">About Us</a>
      </div>

      <!-- Quick menu / areas -->
      <div style="display:flex;flex-direction:column;gap:12px">
        <div style="font:600 11px/1 var(--font-body);letter-spacing:.16em;text-transform:uppercase;color:#cf6a6f">Service Areas</div>
        {towns.slice(0, 7).map((t) => (
          <a class="foot-link" href={`/service-areas/${t.slug}`} style="font:400 14.5px/1.3 var(--font-body)">{t.name}</a>
        ))}
        <a class="foot-link" href="/service-areas" style="font:600 14.5px/1.3 var(--font-body);color:#fff">All areas &rarr;</a>
      </div>

      <!-- Contact + hours -->
      <div style="display:flex;flex-direction:column;gap:12px">
        <div style="font:600 11px/1 var(--font-body);letter-spacing:.16em;text-transform:uppercase;color:#cf6a6f">Get In Touch</div>
        <a class="foot-link" href={business.phoneHref} style="font:700 15px/1.2 var(--font-body);display:flex;align-items:center;gap:8px"><Icon name="phone" size={15} />{business.phoneDisplay}</a>
        <a class="foot-link" href={`mailto:${business.email}`} style="font:400 14px/1.3 var(--font-body);display:flex;align-items:center;gap:8px;word-break:break-all"><Icon name="mail" size={15} />{business.email}</a>
        <div class="foot-link" style="font:400 13.5px/1.4 var(--font-body);display:flex;align-items:flex-start;gap:8px"><span style="margin-top:1px"><Icon name="pin" size={15} /></span>{`{{ADDRESS}}`}<br />Montgomery &amp; Chester County, PA</div>
        <div style="margin-top:6px">
          <div style="font:600 11px/1 var(--font-body);letter-spacing:.12em;text-transform:uppercase;color:#7d899a;margin-bottom:8px;display:flex;align-items:center;gap:7px"><Icon name="clock" size={13} /> Office Hours</div>
          {business.hours.map((h) => (
            <div style="display:flex;justify-content:space-between;gap:14px;font:400 13px/1.7 var(--font-body);color:#9aa6b5"><span>{h.day}</span><span style="color:#c9d0db">{h.time}</span></div>
          ))}
        </div>
      </div>
    </div>

    <div style="height:1px;background:rgba(255,255,255,.1)"></div>

    <div class="stack-sm" style="display:flex;align-items:center;justify-content:space-between;gap:18px;flex-wrap:wrap">
      <div style="font:400 12.5px/1 var(--font-body);color:#7d899a">&copy; {year} {business.name}. All rights reserved. Residential &middot; Commercial &middot; Fully Insured</div>
      <div style="display:flex;gap:18px;font:400 12.5px/1 var(--font-body)">
        <a class="foot-link" href="/privacy">Privacy</a>
        <a class="foot-link" href="/terms">Terms</a>
        <a class="foot-link" href="/sitemap-index.xml">Sitemap</a>
      </div>
    </div>
  </div>
  <style>
    @media (max-width:880px){ footer div[style*="1.4fr 1fr 1fr 1.2fr"]{grid-template-columns:1fr 1fr !important} }
    @media (max-width:560px){ footer div[style*="1.4fr 1fr 1fr 1.2fr"]{grid-template-columns:1fr !important} }
  </style>
</footer>
