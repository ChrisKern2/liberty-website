---
import { business } from "../data/site";
import Icon from "./Icon.astro";
---
<section style="position:relative;overflow:hidden;background:#16243d">
  <!-- Photo background (swap /images/hero-home.jpg with a real photo) -->
  <img
    src="/images/hero-home.jpg"
    alt="Freshly cleaned suburban home with spotless windows and bright siding in Montgomery County, PA"
    width="1600" height="900" fetchpriority="high"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:.34"
  />
  <div style="position:absolute;inset:0;background:radial-gradient(120% 130% at 78% 12%, rgba(33,52,90,.72) 0%, rgba(22,36,61,.88) 46%, rgba(16,27,48,.95) 100%)"></div>
  <div style="position:absolute;top:0;left:0;width:100%;height:4px;background:linear-gradient(90deg,#b3303a 0%,#b3303a 60%,transparent 100%)"></div>

  <div class="wrap" style="position:relative;padding-top:96px;padding-bottom:104px;max-width:900px">
    <div style="display:inline-flex;align-items:center;gap:9px;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.16);padding:8px 15px;border-radius:100px;margin-bottom:22px;color:#cf6a6f">
      <Icon name="star" size={15} />
      <span style="font:600 12.5px/1 var(--font-body);color:#e8c9cb;letter-spacing:.04em">RESIDENTIAL &amp; COMMERCIAL EXTERIOR CLEANING</span>
    </div>

    <h1 class="hero-h1" style="font:700 64px/0.98 var(--font-display);letter-spacing:.005em;color:#fff;text-wrap:balance;margin-bottom:20px">
      SPOTLESS WINDOWS, SIDING &amp; GUTTERS ACROSS <span style="color:#e07a80">MONTGOMERY &amp; CHESTER COUNTY</span>
    </h1>

    <p style="font:400 19px/1.65 var(--font-body);color:#c2cad6;max-width:560px;margin-bottom:30px">
      Professional window cleaning, pressure washing, and gutter care for the western Philadelphia suburbs — licensed, fully insured, and backed by our 100% satisfaction guarantee.
    </p>

    <div class="stack-sm" style="display:flex;align-items:center;gap:16px;flex-wrap:wrap;margin-bottom:26px">
      <a class="btn btn-primary" href="/contact" style="font:700 16px/1 var(--font-body);padding:18px 32px;letter-spacing:.02em">Get a Free Quote <Icon name="arrow" size={18} /></a>
      <a class="btn btn-ghost" href={business.phoneHref} style="font:700 16px/1 var(--font-body);padding:18px 28px">
        <span style="color:#e07a80;display:flex"><Icon name="phone" size={17} /></span>
        or call us today {business.phoneDisplay}
      </a>
    </div>

    <!-- Rating badge -->
    <div style="display:inline-flex;align-items:center;gap:12px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.14);padding:11px 18px;border-radius:12px">
      <span style="display:flex;gap:2px;color:#f0b429">
        <Icon name="star" size={16} /><Icon name="star" size={16} /><Icon name="star" size={16} /><Icon name="star" size={16} /><Icon name="star" size={16} />
      </span>
      <span style="font:600 13.5px/1.3 var(--font-body);color:#e3e8ef">5-star rated &middot; <span style="color:#9aa6b5">{`{{REVIEW_COUNT}}`} reviews</span></span>
    </div>
  </div>
</section>
