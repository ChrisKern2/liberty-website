---
import { stats } from "../data/site";
---
<section style="background:#0f1a30;border-top:1px solid rgba(255,255,255,.06)">
  <div class="wrap" style="padding-top:42px;padding-bottom:42px;display:grid;grid-template-columns:repeat(4,1fr);gap:24px;text-align:center">
    {stats.map((s) => (
      <div style="display:flex;flex-direction:column;gap:6px">
        <div style="font:700 38px/1 var(--font-display);color:#e07a80;letter-spacing:.01em">{s.value}</div>
        <div style="font:600 13px/1.4 var(--font-body);color:#c2cad6;letter-spacing:.02em">{s.label}</div>
      </div>
    ))}
  </div>
  <style>
    @media (max-width:560px){ section[style*="#0f1a30"] > div[style*="repeat(4"]{grid-template-columns:1fr 1fr !important} }
  </style>
</section>
