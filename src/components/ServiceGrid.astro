---
import { services } from "../data/site";
import Icon from "./Icon.astro";
---
<section id="services" style="background:#fff">
  <div class="wrap" style="padding-top:74px;padding-bottom:74px">
    <div style="text-align:center;max-width:640px;margin:0 auto 46px">
      <div style="font:600 12.5px/1 var(--font-body);letter-spacing:.14em;text-transform:uppercase;color:#b3303a;margin-bottom:12px">What We Do</div>
      <h2 style="font:700 40px/1.05 var(--font-display);letter-spacing:.01em;color:#16243d;margin-bottom:14px;text-wrap:balance">Exterior Cleaning, Done Right</h2>
      <p style="font:400 17px/1.6 var(--font-body);color:#5b6675">Three core services, every sub-service you need, and one crew that treats your property like its own.</p>
    </div>

    <div class="grid-3" style="display:grid;grid-template-columns:repeat(3,1fr);gap:26px;align-items:start">
      {services.map((s) => (
        <div class="card card-hover" style="overflow:hidden;display:flex;flex-direction:column">
          <img src={s.image} alt={s.imageAlt} width="690" height="380" loading="lazy"
            style="width:100%;height:190px;object-fit:cover" />
          <div style="padding:26px 26px 28px;display:flex;flex-direction:column;gap:14px;flex:1">
            <div style="display:flex;align-items:center;gap:12px">
              <span style="width:46px;height:46px;border-radius:11px;background:#f4eee1;display:flex;align-items:center;justify-content:center;color:#b3303a;flex:none"><Icon name={s.icon} size={24} /></span>
              <h3 style="font:700 23px/1 var(--font-display);letter-spacing:.01em;color:#16243d">{s.name}</h3>
            </div>
            <p style="font:400 15px/1.6 var(--font-body);color:#5b6675">{s.short}</p>
            <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:9px">
              {s.subservices.map((sub) => (
                <li>
                  <a href={`/services/${s.slug}`} class="nav-link" style="display:flex;align-items:center;gap:9px;text-decoration:none;font:500 14.5px/1.3 var(--font-body);color:#16243d">
                    <span style="color:#1f8a5b;display:flex;flex:none"><Icon name="check" size={16} /></span>{sub.name}
                  </a>
                </li>
              ))}
            </ul>
            <a href={`/services/${s.slug}`} class="btn btn-navy" style="font:700 14px/1 var(--font-body);padding:14px 18px;justify-content:center;margin-top:6px">Explore {s.name} <Icon name="arrow" size={16} /></a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
