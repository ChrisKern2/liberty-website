---
import { business, services } from "../data/site";
import Icon from "./Icon.astro";
import Logo from "./Logo.astro";
---
<header style="position:sticky;top:0;z-index:50;background:rgba(255,255,255,.96);backdrop-filter:blur(8px);border-bottom:1px solid rgba(20,30,50,.08)">
  <div class="wrap" style="padding-top:13px;padding-bottom:13px;display:flex;align-items:center;justify-content:space-between;gap:24px">
    <Logo variant="dark" size={26} />

    <nav style="display:flex;align-items:center;gap:28px">
      <div class="nav-links" style="display:flex;align-items:center;gap:28px">
        <!-- Services mega-menu -->
        <div class="has-mega">
          <a class="nav-link" href="/#services" style="font:600 14px/1 var(--font-body);color:#16243d;display:flex;align-items:center;gap:5px">
            Services <span style="display:flex;color:#5b6675"><Icon name="chevron" size={14} /></span>
          </a>
          <div class="mega">
            {services.map((s) => (
              <div style="margin-bottom:6px">
                <a href={`/services/${s.slug}`} class="mega-item" style="border-bottom:1px solid rgba(20,30,50,.06);border-radius:9px 9px 0 0">
                  <strong style="color:#b3303a">{s.name}</strong>
                  <span>{s.short}</span>
                </a>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:1px 8px;padding:6px 4px 10px">
                  {s.subservices.map((sub) => (
                    <a href={`/services/${s.slug}`} class="mega-item" style="padding:6px 8px">
                      <strong style="font-weight:500;font-size:13px">{sub.name}</strong>
                    </a>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>

        <a class="nav-link" href="/service-areas" style="font:600 14px/1 var(--font-body);color:#16243d">Service Areas</a>
        <a class="nav-link" href="/about" style="font:600 14px/1 var(--font-body);color:#16243d">About</a>
        <a class="nav-link" href="/contact" style="font:600 14px/1 var(--font-body);color:#16243d">Contact</a>

        <a href={business.phoneHref} style="font:700 15px/1 var(--font-display);letter-spacing:.03em;color:#16243d;text-decoration:none;display:flex;align-items:center;gap:8px">
          <span style="color:#b3303a;display:flex"><Icon name="phone" size={16} /></span>
          {business.phoneDisplay}
        </a>
      </div>

      <a class="btn btn-primary" href="/contact" style="font:700 14px/1 var(--font-body);padding:13px 22px;letter-spacing:.02em">Get a Free Quote</a>

      <!-- Mobile toggle -->
      <button id="navToggle" class="mobile-toggle" aria-label="Open menu" aria-expanded="false" style="display:none;background:none;border:none;cursor:pointer;color:#16243d;padding:4px">
        <Icon name="menu" size={26} />
      </button>
    </nav>
  </div>

  <!-- Mobile menu -->
  <div id="mobileMenu" style="display:none;border-top:1px solid rgba(20,30,50,.08);background:#fff">
    <div class="wrap" style="padding-top:14px;padding-bottom:18px;display:flex;flex-direction:column;gap:4px">
      {services.map((s) => (
        <a href={`/services/${s.slug}`} style="font:600 15px/1 var(--font-body);color:#16243d;text-decoration:none;padding:11px 4px;border-bottom:1px solid rgba(20,30,50,.06)">{s.name}</a>
      ))}
      <a href="/service-areas" style="font:600 15px/1 var(--font-body);color:#16243d;text-decoration:none;padding:11px 4px;border-bottom:1px solid rgba(20,30,50,.06)">Service Areas</a>
      <a href="/about" style="font:600 15px/1 var(--font-body);color:#16243d;text-decoration:none;padding:11px 4px;border-bottom:1px solid rgba(20,30,50,.06)">About</a>
      <a href="/contact" style="font:600 15px/1 var(--font-body);color:#16243d;text-decoration:none;padding:11px 4px">Contact</a>
      <a href={business.phoneHref} class="btn btn-navy" style="font:700 15px/1 var(--font-body);padding:14px;justify-content:center;margin-top:10px">Call {business.phoneDisplay}</a>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById("navToggle");
  const menu = document.getElementById("mobileMenu");
  toggle?.addEventListener("click", () => {
    const open = menu?.style.display === "block";
    if (menu) menu.style.display = open ? "none" : "block";
    toggle.setAttribute("aria-expanded", open ? "false" : "true");
  });
</script>
