---
// The Liberty Exterior Co. wordmark lockup. `variant` flips colors for
// light vs. dark backgrounds. Size scales the LIBERTY wordmark.
interface Props { variant?: "dark" | "light"; size?: number; href?: string; }
const { variant = "dark", size = 26, href = "/" } = Astro.props;
const text = variant === "light" ? "#fff" : "#16243d";
const rule = variant === "light" ? "#f4eee1" : "#16243d";
const star = variant === "light" ? "#cf6a6f" : "#b3303a";
const sub = variant === "light" ? "#f4eee1" : "#16243d";
---
<a href={href} aria-label="Liberty Exterior Co. home" style="text-decoration:none;display:flex;flex-direction:column;align-items:center;gap:4px">
  <div style="display:flex;align-items:center;gap:8px">
    <div style={`width:20px;height:1.5px;background:${star}`}></div>
    <svg width="11" height="11" viewBox="0 0 24 24" fill={star} aria-hidden="true"><path d="M12 1 L14.6 8.2 L22.3 8.5 L16.2 13.3 L18.3 20.8 L12 16.3 L5.7 20.8 L7.8 13.3 L1.7 8.5 L9.4 8.2 Z"/></svg>
    <div style={`width:20px;height:1.5px;background:${star}`}></div>
  </div>
  <div style={`font:700 ${size}px/0.84 var(--font-display);letter-spacing:.015em;color:${text}`}>LIBERTY</div>
  <div style="display:flex;align-items:center;gap:7px;align-self:stretch">
    <div style={`flex:1;height:1px;background:${rule}`}></div>
    <div style={`font:600 7.5px/1 var(--font-body);letter-spacing:.34em;color:${sub};white-space:nowrap`}>EXTERIOR&nbsp;CO.</div>
    <div style={`flex:1;height:1px;background:${rule}`}></div>
  </div>
</a>
