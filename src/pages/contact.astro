---
import Layout from "../layouts/Layout.astro";
import TopBar from "../components/TopBar.astro";
import Header from "../components/Header.astro";
import PageHero from "../components/PageHero.astro";
import QuoteForm from "../components/QuoteForm.astro";
import Footer from "../components/Footer.astro";
import Icon from "../components/Icon.astro";
import { business } from "../data/site";
---
<Layout
  title="Contact Liberty Exterior Co. | Free Same-Day Quotes, PA"
  description="Contact Liberty Exterior Co. for window cleaning, pressure washing & gutter care in Montgomery & Chester County. Call (215) 978-9719 or request a free same-day quote."
  path="/contact"
>
  <TopBar />
  <Header />
  <PageHero
    eyebrow="Contact"
    title="Get Your Free, Same-Day Quote"
    subtitle="Send us a message or call — we respond the same day with a clear, no-obligation price."
    crumbs={[{ label: "Home", href: "/" }, { label: "Contact" }]}
  />

  <section style="background:#fff">
    <div class="wrap hero-grid" style="padding-top:64px;padding-bottom:70px;display:grid;grid-template-columns:1fr 1.1fr;gap:48px;align-items:start">
      <div style="display:flex;flex-direction:column;gap:22px">
        <div>
          <h2 style="font:700 30px/1.1 var(--font-display);color:#16243d;margin-bottom:12px;letter-spacing:.01em">Talk to a Real Local</h2>
          <p style="font:400 16.5px/1.7 var(--font-body);color:#42505f;max-width:420px">Have a question or ready to book? Reach us any of these ways — or fill out the form and we'll come to you.</p>
        </div>

        <div style="display:flex;flex-direction:column;gap:16px">
          <a href={business.phoneHref} style="display:flex;align-items:center;gap:13px;text-decoration:none">
            <span style="width:46px;height:46px;border-radius:11px;background:#f4eee1;display:flex;align-items:center;justify-content:center;color:#b3303a;flex:none"><Icon name="phone" size={22} /></span>
            <span style="display:flex;flex-direction:column"><span style="font:600 12px/1 var(--font-body);color:#8a92a0;letter-spacing:.06em;text-transform:uppercase">Call or text</span><span style="font:700 19px/1.3 var(--font-display);color:#16243d;letter-spacing:.02em">{business.phoneDisplay}</span></span>
          </a>
          <a href={`mailto:${business.email}`} style="display:flex;align-items:center;gap:13px;text-decoration:none">
            <span style="width:46px;height:46px;border-radius:11px;background:#f4eee1;display:flex;align-items:center;justify-content:center;color:#b3303a;flex:none"><Icon name="mail" size={22} /></span>
            <span style="display:flex;flex-direction:column"><span style="font:600 12px/1 var(--font-body);color:#8a92a0;letter-spacing:.06em;text-transform:uppercase">Email</span><span style="font:600 16px/1.3 var(--font-body);color:#16243d;word-break:break-all">{business.email}</span></span>
          </a>
          <div style="display:flex;align-items:flex-start;gap:13px">
            <span style="width:46px;height:46px;border-radius:11px;background:#f4eee1;display:flex;align-items:center;justify-content:center;color:#b3303a;flex:none"><Icon name="clock" size={22} /></span>
            <span style="display:flex;flex-direction:column;gap:3px">
              <span style="font:600 12px/1 var(--font-body);color:#8a92a0;letter-spacing:.06em;text-transform:uppercase;margin-bottom:3px">Office Hours</span>
              {business.hours.map((h) => (
                <span style="font:500 14px/1.4 var(--font-body);color:#16243d;display:flex;gap:10px"><span style="min-width:74px;color:#5b6675">{h.day}</span><span>{h.time}</span></span>
              ))}
            </span>
          </div>
        </div>
      </div>

      <div>
        <h2 style="font:700 22px/1.1 var(--font-display);color:#16243d;margin-bottom:16px;letter-spacing:.01em">Request a Free Quote</h2>
        <QuoteForm />
      </div>
    </div>
  </section>

  <Footer />
</Layout>
