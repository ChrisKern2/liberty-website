---
import Layout from "../../layouts/Layout.astro";
import TopBar from "../../components/TopBar.astro";
import Header from "../../components/Header.astro";
import PageHero from "../../components/PageHero.astro";
import ServiceAreaList from "../../components/ServiceAreaList.astro";
import CTABand from "../../components/CTABand.astro";
import Footer from "../../components/Footer.astro";
import { business } from "../../data/site";
---
<Layout
  title="Service Areas | Exterior Cleaning in Montgomery & Chester County, PA"
  description="Liberty Exterior Co. serves Blue Bell, Malvern, Exton, West Chester, Ambler, Wayne & more across Montgomery and Chester County. Find your town and get a free quote."
  path="/service-areas"
>
  <TopBar />
  <Header />
  <PageHero
    eyebrow="Where We Work"
    title="Exterior Cleaning Across the Western Philadelphia Suburbs"
    subtitle="Locally owned and serving Montgomery and Chester County. Find your town below — or call to confirm we cover your street."
    crumbs={[{ label: "Home", href: "/" }, { label: "Service Areas" }]}
  />
  <section style="background:#fff">
    <div class="wrap" style="padding-top:56px;padding-bottom:10px;max-width:820px">
      <p class="prose" style="text-align:center"><span style="font:400 17px/1.7 var(--font-body);color:#42505f">Liberty Exterior Co. brings professional window cleaning, pressure washing, and gutter care to homes and businesses throughout the western Philadelphia suburbs. Click your town for local details, or reach us at <a href={business.phoneHref} style="color:#b3303a;font-weight:600;text-decoration:none">{business.phoneDisplay}</a>.</span></p>
    </div>
  </section>
  <ServiceAreaList heading={false} />
  <CTABand tone="red" />
  <Footer />
</Layout>
