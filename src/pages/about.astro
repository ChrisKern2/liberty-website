---
import Layout from "../layouts/Layout.astro";
import TopBar from "../components/TopBar.astro";
import Header from "../components/Header.astro";
import PageHero from "../components/PageHero.astro";
import WhyChooseGrid from "../components/WhyChooseGrid.astro";
import StatBand from "../components/StatBand.astro";
import CTABand from "../components/CTABand.astro";
import Footer from "../components/Footer.astro";
import Icon from "../components/Icon.astro";
import { business } from "../data/site";
---
<Layout
  title="About Liberty Exterior Co. | Locally Owned Exterior Cleaning, PA"
  description="Liberty Exterior Co. is a locally owned, licensed & insured exterior cleaning company serving Montgomery & Chester County, PA. Honest pricing, careful crews, real guarantee."
  path="/about"
>
  <TopBar />
  <Header />
  <PageHero
    eyebrow="About Us"
    title="Locally Owned. Honestly Run. Built on Careful Work."
    subtitle="Liberty Exterior Co. is a new kind of exterior cleaning company for Montgomery and Chester County — one built on transparency, craftsmanship, and treating every home like our own."
    crumbs={[{ label: "Home", href: "/" }, { label: "About" }]}
  />

  <section style="background:#fff">
    <div class="wrap" style="padding-top:70px;padding-bottom:60px;max-width:820px">
      <div class="prose">
        <h2 style="font:700 32px/1.1 var(--font-display);color:#16243d;margin-bottom:18px;letter-spacing:.01em">Our Story</h2>
        <p>Liberty Exterior Co. was founded in {business.foundedYear} with a simple idea: exterior cleaning should be easy to trust. Too many homeowners have been burned by no-shows, surprise charges, and rushed work that does more harm than good. We started Liberty to do the opposite — show up on time, quote honestly, use the right method for every surface, and stand behind the result.</p>
        <p>We're locally owned and operated, which means when you call, you're talking to people who live and work in the same Montgomery and Chester County neighborhoods we serve. We know the homes here — the Main Line stone, the vinyl-sided developments, the historic borough storefronts — and we know how to clean each one without cutting corners or causing damage.</p>
        <p>Every job is fully insured and handled by careful crews who protect your landscaping, cover your fixtures, and walk the work with you before they leave. We're new, and we're earning our reputation the only way that lasts: one meticulous job at a time. When we say 100% satisfaction guarantee, we mean it — if it's not right, we make it right.</p>
      </div>

      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-top:38px">
        {[
          { icon: "shield", t: "Licensed & Insured", b: "Fully covered on every job, every visit." },
          { icon: "home", t: "Locally Owned", b: "Your neighbors in Montgomery & Chester County." },
          { icon: "badge", t: "Satisfaction Guaranteed", b: "We make it right or it's not done." },
        ].map((c) => (
          <div class="card" style="padding:24px;display:flex;flex-direction:column;gap:10px">
            <span style="width:44px;height:44px;border-radius:11px;background:#f4eee1;display:flex;align-items:center;justify-content:center;color:#b3303a"><Icon name={c.icon} size={22} /></span>
            <h3 style="font:700 17px/1.2 var(--font-body);color:#16243d">{c.t}</h3>
            <p style="font:400 14px/1.6 var(--font-body);color:#5b6675">{c.b}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <WhyChooseGrid />
  <StatBand />
  <CTABand tone="red" />
  <Footer />
</Layout>
