---
import Layout from "../../layouts/Layout.astro";
import TopBar from "../../components/TopBar.astro";
import Header from "../../components/Header.astro";
import PageHero from "../../components/PageHero.astro";
import CTABand from "../../components/CTABand.astro";
import ServiceAreaList from "../../components/ServiceAreaList.astro";
import Footer from "../../components/Footer.astro";
import Icon from "../../components/Icon.astro";
import { business, services } from "../../data/site";

export function getStaticPaths() {
  return services.map((s) => ({ params: { service: s.slug }, props: { service: s } }));
}

const { service } = Astro.props;
const path = `/services/${service.slug}`;
const site = business.domain;

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: `${service.name} in Montgomery & Chester County, PA`,
  serviceType: service.name,
  description: service.metaDescription,
  url: new URL(path, site).href,
  provider: { "@id": `${site}/#business` },
  areaServed: business.counties.map((c) => ({ "@type": "AdministrativeArea", name: `${c}, PA` })),
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: service.name,
    itemListElement: service.subservices.map((sub) => ({
      "@type": "Offer",
      itemOffered: { "@type": "Service", name: sub.name },
    })),
  },
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: service.faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---
<Layout
  title={service.metaTitle}
  description={service.metaDescription}
  path={path}
  image={service.image}
  schema={[serviceSchema, faqSchema]}
>
  <TopBar />
  <Header />
  <PageHero
    eyebrow="Exterior Cleaning Services"
    title={`${service.name} in Montgomery & Chester County, PA`}
    subtitle={service.short}
    image={service.image}
    imageAlt={service.imageAlt}
    crumbs={[{ label: "Home", href: "/" }, { label: "Services", href: "/#services" }, { label: service.name }]}
  />

  <!-- BODY + WHAT'S INCLUDED -->
  <section style="background:#fff">
    <div class="wrap hero-grid" style="padding-top:70px;padding-bottom:60px;display:grid;grid-template-columns:1.4fr 1fr;gap:48px;align-items:start">
      <div class="prose">
        <h2 style="font:700 32px/1.1 var(--font-display);color:#16243d;margin-bottom:18px;letter-spacing:.01em">Professional {service.name} You Can Count On</h2>
        {service.intro.map((p) => <p set:html={p} />)}
      </div>
      <aside class="card" style="padding:28px;background:#f4eee1;border:none">
        <h3 style="font:700 20px/1.1 var(--font-display);color:#16243d;margin-bottom:16px;letter-spacing:.01em">What's Included</h3>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:12px">
          {service.included.map((i) => (
            <li style="display:flex;align-items:flex-start;gap:10px"><span style="color:#1f8a5b;margin-top:1px;flex:none"><Icon name="check" size={18} /></span><span style="font:500 14.5px/1.5 var(--font-body);color:#16243d">{i}</span></li>
          ))}
        </ul>
        <a class="btn btn-primary" href="/contact" style="font:700 15px/1 var(--font-body);padding:15px 22px;justify-content:center;margin-top:22px;width:100%">Get a Free Quote</a>
      </aside>
    </div>
  </section>

  <!-- SUB-SERVICES -->
  <section style="background:#f7f4ec">
    <div class="wrap" style="padding-top:64px;padding-bottom:64px">
      <h2 style="font:700 32px/1.1 var(--font-display);color:#16243d;margin-bottom:8px;letter-spacing:.01em">Our {service.name} Services</h2>
      <p style="font:400 16px/1.6 var(--font-body);color:#5b6675;margin-bottom:34px;max-width:620px">Whatever your property needs, we've got it covered.</p>
      <div class="grid-3" style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px">
        {service.subservices.map((sub) => (
          <div class="card" style="padding:24px;display:flex;flex-direction:column;gap:9px">
            <span style="width:42px;height:42px;border-radius:10px;background:#f4eee1;display:flex;align-items:center;justify-content:center;color:#b3303a"><Icon name={service.icon} size={21} /></span>
            <h3 style="font:700 17px/1.25 var(--font-body);color:#16243d">{sub.name}</h3>
            <p style="font:400 14px/1.6 var(--font-body);color:#5b6675">{sub.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section style="background:#16243d">
    <div class="wrap" style="padding-top:64px;padding-bottom:64px">
      <h2 style="font:700 32px/1.1 var(--font-display);color:#fff;margin-bottom:34px;letter-spacing:.01em;text-align:center">How It Works</h2>
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:20px">
        {service.process.map((step, i) => (
          <div style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.09);border-radius:14px;padding:24px;display:flex;flex-direction:column;gap:10px">
            <span style="font:700 28px/1 var(--font-display);color:#e07a80">{String(i + 1).padStart(2, "0")}</span>
            <h3 style="font:700 16.5px/1.2 var(--font-body);color:#fff">{step.title}</h3>
            <p style="font:400 13.5px/1.6 var(--font-body);color:#9aa6b5">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
    <style>
      @media (max-width:880px){ section[style*="#16243d"] div[style*="repeat(4"]{grid-template-columns:1fr 1fr !important} }
      @media (max-width:560px){ section[style*="#16243d"] div[style*="repeat(4"]{grid-template-columns:1fr !important} }
    </style>
  </section>

  <!-- FAQ -->
  <section style="background:#fff">
    <div class="wrap" style="padding-top:64px;padding-bottom:64px;max-width:820px">
      <h2 style="font:700 32px/1.1 var(--font-display);color:#16243d;margin-bottom:28px;letter-spacing:.01em;text-align:center">{service.name} FAQs</h2>
      <div style="display:flex;flex-direction:column;gap:14px">
        {service.faqs.map((f) => (
          <details class="card" style="padding:0;overflow:hidden">
            <summary style="cursor:pointer;list-style:none;padding:20px 24px;font:700 16.5px/1.4 var(--font-body);color:#16243d;display:flex;justify-content:space-between;gap:16px;align-items:center">
              {f.q}<span style="color:#b3303a;flex:none"><Icon name="chevron" size={20} /></span>
            </summary>
            <p style="padding:0 24px 22px;font:400 15.5px/1.7 var(--font-body);color:#42505f">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <ServiceAreaList heading={true} />
  <CTABand tone="red" title={`Ready for ${service.name}?`} subtitle="Get your free, same-day quote now — or call and talk it through with us." />
  <Footer />
</Layout>

<style>
  details summary::-webkit-details-marker{display:none}
  details[open] summary span{transform:rotate(180deg)}
  details summary span{transition:transform .18s}
</style>
